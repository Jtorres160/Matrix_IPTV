{
  "name": "iptvsupreme",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron ./electron/main.cjs",
    "desktop": "concurrently -k \"npm:dev\" \"npm:electron\"",
    "build": "vite build",
    "make:exe": "npm run build && electron-builder --win portable",
    "preview": "vite preview --port 5173",
    "lint": "eslint . --ext .js,.jsx --fix"
  },
  "build": {
    "appId": "com.matrix.iptv",
    "productName": "Matrix IPTV",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/keygen.cjs",
      "!electron/private-key.pem",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-store": "^11.0.2",
    "lucide-react": "^1.24.0",
    "mpegts.js": "^1.8.0",
    "nanoid": "^5.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-player": "^2.16.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.12",
    "playwright-core": "^1.61.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "vite": "^5.4.0"
  }
}
